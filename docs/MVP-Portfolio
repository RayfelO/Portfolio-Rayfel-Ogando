    opacity: 1,
    transition: { staggerChildren: 0.05, delayChildren: 0.1 }
  }
}

const card = {
  hidden: { opacity: 0, y: 12 },
  show: {
    opacity: 1,
    y: 0,
    transition: { duration: 0.35, ease: [0.16, 1, 0.3, 1] }
  }
}

// Hover en project rows
const projectRow = {
  rest: { x: 0 },
  hover: { x: 2, transition: { duration: 0.15 } }
}
```

**Reglas de animación:**
- Nada que dure más de 400ms
- Ease curve: `[0.16, 1, 0.3, 1]` (igual a Linear's spring)
- Sin bounce, sin rotaciones, sin scale en cards grandes
- Solo `y`, `opacity`, y `x` sutil en rows

